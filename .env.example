APP_ENV=development
APP_ROLE=api
PORT=10000
SEER_VERSION=0.1.0

DATABASE_URL=postgresql://user@localhost/seer
RUN_MIGRATIONS=false
RUN_INTERNAL_JOBS=true
REDIS_URL=redis://localhost:6379

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

NANSEN_API_KEY=
NANSEN_BASE_URL=https://api.nansen.ai/api/v1
NANSEN_CLI_PATH=nansen
NANSEN_SMART_MONEY_CHAINS=ethereum,base,mantle
DEFILLAMA_ENABLED=true
DEFILLAMA_BASE_URL=https://api.llama.fi
DEFILLAMA_YIELDS_BASE_URL=https://yields.llama.fi

MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
# Read-only RPC for user portfolio data (token balances, native balance, wallet
# activity). Defaults to Mantle mainnet, where real holdings live, while
# MANTLE_RPC_URL stays on the chain where Seer's contracts are deployed.
MANTLE_DATA_RPC_URL=https://rpc.mantle.xyz
MANTLE_CHAIN_ID=5003
AA_PROVIDER_STACK=safe-4337-relay-kit
AA_BUNDLER_URL=
AA_ENTRY_POINT_ADDRESS=
AA_PAYMASTER_URL=

BACKEND_SIGNER_PRIVATE_KEY=

# Token contract addresses for portfolio balance reads. Use addresses on the
# chain MANTLE_DATA_RPC_URL points at (Mantle mainnet for real holdings).
# MNT is the native gas token: keep the dead0000 placeholder (read via balance).
MANTLE_USDC_ADDRESS=
MANTLE_USDT_ADDRESS=
MANTLE_MNT_ADDRESS=
MANTLE_METH_ADDRESS=
# Execution-chain token addresses for transaction drafts ("SYMBOL:0xADDR,...").
# Required when MANTLE_*_ADDRESS points at mainnet but execution targets testnet.
# For live validation, USDC can point at a SeerTestToken deployed on Sepolia.
SEER_EXEC_TOKEN_ADDRESSES=
SEER_APPROVED_STRATEGY_ADDRESS=
SEER_APPROVED_STRATEGY_SPENDER_ADDRESS=
SEER_STRATEGY_DEPOSIT_FUNCTION=deposit(address,uint256)
SEER_MERCHANT_MOE_STRATEGY_ADDRESS=
SEER_MERCHANT_MOE_SPENDER_ADDRESS=
SEER_MERCHANT_MOE_DEPOSIT_FUNCTION=
SEER_LENDLE_STRATEGY_ADDRESS=
SEER_LENDLE_SPENDER_ADDRESS=
SEER_LENDLE_DEPOSIT_FUNCTION=
SEER_AGNI_STRATEGY_ADDRESS=
SEER_AGNI_SPENDER_ADDRESS=
SEER_AGNI_DEPOSIT_FUNCTION=
SEER_METH_STRATEGY_ADDRESS=
SEER_METH_SPENDER_ADDRESS=
SEER_METH_DEPOSIT_FUNCTION=

SEER_ARENA_POINTS_ADDRESS=
SEER_PREDICTION_REGISTRY_ADDRESS=
SEER_IDENTITY_SBT_ADDRESS=
SEER_INTENT_REGISTRY_ADDRESS=

IPFS_API_KEY=
IPFS_API_SECRET=
IPFS_GATEWAY_URL=
